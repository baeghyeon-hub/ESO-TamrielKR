<GuiXml>
    <!-- TamrielKR slug → ESO 원본 폰트 (확장 라틴/특수문자 보완) -->
    <!-- ESO 원본 → 한글 slug 체이닝은 아래 섹션에서 정의됨 -->
    <BackupFont originalFont="TamrielKR/fonts/ftn47.slug" backupFont="$(FTN47_FONT)"/>
    <BackupFont originalFont="TamrielKR/fonts/ftn57.slug" backupFont="$(FTN57_FONT)"/>
