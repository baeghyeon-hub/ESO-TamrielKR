    <BackupFont originalFont="$(UNIVERS67_FONT)" backupFont="TamrielKR/fonts/kr_maruburi_cnkr.slug"/>

    <BackupFont originalFont="$(UNIVERS55_FONT)" backupFont="TamrielKR/fonts/kr_maruburi_cnkr.slug"/>
