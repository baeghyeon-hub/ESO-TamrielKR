[SI_GUILD_INFO_SCENE_TITLE] = "길드 정보"
[SI_GUILD_INTRODUCTION] = "길드는 탐리엘을 거닐며 만나게된 수많은 여행자들과 팀을 이룰 수 있는 편리한 시스템입니다!\n길드에 들면 다른 플레이어들과 뭉치거나, 같이 목표를 정하고 수행하거나, 길드 상점같은 특전을 얻을 수 있습니다."
