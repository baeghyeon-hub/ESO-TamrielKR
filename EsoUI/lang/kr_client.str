[SI_ATTRIBUTE_RESPEC_CONFIRM_DIALOG_TITLE] = "변경 확인"
[SI_ATTRIBUTE_TOOLTIP_HEALTH] = "당신이 전투하는 동안 견뎌낼 수 있는 피해량과 얼마나 치유받을 수 있는지를 결정합니다. 체력은 시간이 지남에 따라 회복되며, 전투 중이 아닐 때는 회복 속도가 더 빨라집니다."
[SI_ATTRIBUTE_TOOLTIP_MAGICKA] = "매지카와 관련된 어빌리티를 얼마나 사용할 수 있을지 결정합니다. 매지카는 시간이 지남에 따라 회복되며, 전투 중이 아닐 때는 회복 속도가 더 빨라집니다. 스태프로 완전히 충전된 강공격 또한 매지카를 회복합니다."
[SI_ATTRIBUTE_TOOLTIP_STAMINA] = "스태미나와 관련된 어빌리티는 물론 달리기, 밀치기, 은신, 구르기, 벗어나기 등을 얼마나 사용할 수 있을지 결정합니다. 스태미나는 시간이 지남에 따라 회복되며, 전투 중이 아닐 때는 회복 속도가 더 빨라집니다. 근거리 무기 또는 활로 완전히 충전된 강공격 또한 스태미나를 회복합니다."
