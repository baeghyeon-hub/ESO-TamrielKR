[SI_GRAPHICS_OPTIONS_VIDEO_CHARACTER_RESOLUTION_TOOLTIP] = "플레이어 주변에 고해상도 캐릭터가 표시되는 수와 거리 기준을 설정합니다."
[SI_GRAPHICS_OPTIONS_VIDEO_CLUTTER_2D_QUALITY] = "풀 조절"
[SI_GRAPHICS_OPTIONS_VIDEO_CLUTTER_2D_QUALITY_TOOLTIP] = "월드에 나타나는 풀과 지형 군체의 양을 설정합니다. 설정이 높을수록 풀이 보이는 거리가 증가합니다. 이 설정을 낮추면 성능이 향상될 수 있습니다."
[SI_GRAPHICS_OPTIONS_VIDEO_DEPTH_OF_FIELD_MODE] = "피사계 심도"
[SI_GRAPHICS_OPTIONS_VIDEO_DEPTH_OF_FIELD_MODE_TOOLTIP] = "피사계 심도가 보이는 정도를 설정합니다. 피사계 심도는 멀리 있는 물체가 전경에 있는 물체와의 거리에 따라 초점이 맞지 않는 사진 효과처럼 보이게 합니다."
