[SI_GRAPHICS_OPTIONS_VIDEO_HDR_PEAK_BRIGHTNESS_TOOLTIP] = "HDR의 최대 밝기를 설정합니다."
[SI_GRAPHICS_OPTIONS_VIDEO_HDR_SCENE_BRIGHTNESS] = "HDR 씬의 밝기"
[SI_GRAPHICS_OPTIONS_VIDEO_HDR_SCENE_BRIGHTNESS_TOOLTIP] = "HDR 씬의 밝기를 조정합니다."
[SI_GRAPHICS_OPTIONS_VIDEO_HDR_SCENE_CONTRAST] = "HDR 씬의 대조"
[SI_GRAPHICS_OPTIONS_VIDEO_HDR_SCENE_CONTRAST_TOOLTIP] = "HDR 씬의 대조를 조정합니다."
[SI_GRAPHICS_OPTIONS_VIDEO_HDR_UI_BRIGHTNESS] = "HDR UI 밝기"
[SI_GRAPHICS_OPTIONS_VIDEO_HDR_UI_BRIGHTNESS_TOOLTIP] = "HDR UI 밝기를 설정합니다."
[SI_GRAPHICS_OPTIONS_VIDEO_HDR_UI_CONTRAST] = "HDR UI 대비"
[SI_GRAPHICS_OPTIONS_VIDEO_HDR_UI_CONTRAST_TOOLTIP] = "HDR UI 대비를 설정합니다."
[SI_GRAPHICS_OPTIONS_VIDEO_MAC_AMBIENT_OCCLUSION_TYPE_TOOLTIP] = "빛을 가리는 물체를 고려하여 그림자와 조명의 품질을 향상시킵니다. HBAO는 SSAO보다 리얼하며 성능 비용이 더 큽니다. 이 설정을 끄면 성능이 향상될 수 있습니다."
[SI_GRAPHICS_OPTIONS_VIDEO_MAXIMUM_PARTICLE_SYSTEMS] = "최대 파티클 개수"
[SI_GRAPHICS_OPTIONS_VIDEO_MAXIMUM_PARTICLE_SYSTEMS_RESTRICTION] = "로그아웃이나 새로운 장소로 이동하면 적용됩니다."
[SI_GRAPHICS_OPTIONS_VIDEO_MAXIMUM_PARTICLE_SYSTEMS_TOOLTIP] = "얼마나 많은 입자들이 화면에 표시될지 설정합니다. 이 옵션을 감소시키면 화면에는 더 적은 입자들이 표시되지만,  성능이 향상될 수 있습니다."
[SI_GRAPHICS_OPTIONS_VIDEO_OCCLUSION_CULLING_ENABLED] = "소프트웨어 오클루전 컬링"
[SI_GRAPHICS_OPTIONS_VIDEO_OCCLUSION_CULLING_ENABLED_TOOLTIP] = "오클루전 컬링이 활성화된 경우 제어한다. 오클루전 컬링은 CPU를 더 많이 사용하고 GPU의 워크로드를 낮춘다. 프레임 속도가 GPU에 의해 제한될 때 사용한다."
[SI_GRAPHICS_OPTIONS_VIDEO_PARTICLE_SUPPRESSION_DISTANCE] = "파티클 억제 거리"
[SI_GRAPHICS_OPTIONS_VIDEO_PARTICLE_SUPPRESSION_DISTANCE_TOOLTIP] = "사소한 파티클이 보이는 거리를 조절합니다. 이 설정을 높일수록 성능은 하락하지만, 멀리에서도 사소한 파티클이 보입니다."
[SI_GRAPHICS_OPTIONS_VIDEO_PLANAR_WATER_REFLECTION_QUALITY] = "평면 반사 품질"
[SI_GRAPHICS_OPTIONS_VIDEO_PLANAR_WATER_REFLECTION_QUALITY_TOOLTIP] = "수면에 보이는 평면 반사의 해상도 및 세부 사항을 설정합니다. 평면 반사를 켜면 품질이 상향되지만, 성능이 저하될 수 있습니다. 평면 반사를 적용할 수 없는 물은 스크린 스페이스 반사 설정으로 되돌아갑니다."
[SI_GRAPHICS_OPTIONS_VIDEO_PRESETS] = "그래픽 품질"
[SI_GRAPHICS_OPTIONS_VIDEO_PRESETS_TOOLTIP] = "게임의 전체적 그래픽 품질을 조절합니다. 세부적인 옵션은 아래에서 설정 가능합니다."
[SI_GRAPHICS_OPTIONS_VIDEO_RENDER_THREAD] = "멀티스레드 렌더링 (베타)"
[SI_GRAPHICS_OPTIONS_VIDEO_RENDER_THREAD_TOOLTIP] = "렌더 프로세스의 별도 스레드를 활성화하여 성능을 향상시킬 수 있습니다."
[SI_GRAPHICS_OPTIONS_VIDEO_RESOLUTION] = "해상도"
[SI_GRAPHICS_OPTIONS_VIDEO_RESOLUTION_FORMAT] = "<<1>>x<<2>>"
[SI_GRAPHICS_OPTIONS_VIDEO_RESOLUTION_FORMAT_WIDE] = "<<1>>x<<2>> (와이드)"
[SI_GRAPHICS_OPTIONS_VIDEO_RESOLUTION_TOOLTIP] = "게임의 해상도를 설정합니다. 해상도가 높을수록 화면이 더 세밀하게 표현되지만, 성능에 영향을 미칩니다. 해상도는 모니터의 화면 크기에 따라 선택하는 것이 좋습니다."
[SI_GRAPHICS_OPTIONS_VIDEO_SCREENSPACE_WATER_REFLECTION_QUALITY] = "스크린 스페이스 반사 품질"
[SI_GRAPHICS_OPTIONS_VIDEO_SCREENSPACE_WATER_REFLECTION_QUALITY_TOOLTIP] = "수면에 보이는 스크린 스페이스 반사의 품질을 결정합니다. 이 설정을 높일수록 반사 정확도가 향상되지만, 성능이 저하될 수 있습니다."
[SI_GRAPHICS_OPTIONS_VIDEO_SHADOWS] = "그림자 품질"
[SI_GRAPHICS_OPTIONS_VIDEO_SHADOWS_TOOLTIP] = "그림자의 품질을 설정합니다. 이 설정을 높일수록 그림자를 표현하는 사정거리가 커지고, 그림자가 더 선명해지며, 그림자가 표시되는 물체가 많아집니다. 이 설정을 감소시키면 성능이 향상됩니다."
[SI_GRAPHICS_OPTIONS_VIDEO_SHOW_ADDITIONAL_ALLY_EFFECTS] = "추가 아군 이펙트 보이기"
[SI_GRAPHICS_OPTIONS_VIDEO_SHOW_ADDITIONAL_ALLY_EFFECTS_TOOLTIP] = "던전이나 지상 구역에 있을 때 영구적인 동맹의 공격 효과을 모두 표시합니다. 이를 비활성화하면 성능이 향상될 수 있습니다."
[SI_GRAPHICS_OPTIONS_VIDEO_SUB_SAMPLING] = "서브샘플링 품질"
[SI_GRAPHICS_OPTIONS_VIDEO_SUB_SAMPLING_TOOLTIP] = "게임이 월드를 렌더링하는 해상도를 설정합니다. 인터페이스는 이 설정의 영향을 받지 않습니다. 이 설정을 낮추면 성능이 향상될 수 있습니다."
[SI_GRAPHICS_OPTIONS_VIDEO_TEXTURE_RES] = "텍스쳐 품질"
[SI_GRAPHICS_OPTIONS_VIDEO_TEXTURE_RES_TOOLTIP] = "텍스쳐의 크기를 변경하고 품질을 설정합니다. 이 설정을 높일수록 물체, 캐릭터 모델, 배경이 보다 상세히 표시되지만, 쾌적하게 플레이하려면 더 큰 용량의 비디오 메모리가 필요합니다."
[SI_GRAPHICS_OPTIONS_VIDEO_VIEW_DISTANCE] = "가시 거리"
[SI_GRAPHICS_OPTIONS_VIDEO_VIEW_DISTANCE_TOOLTIP] = "게임 내에서 물체가 보이지 않는 거리를 조절합니다. 이 설정을 높일수록 보다 풍요롭고 현실적인 배경이 표현되지만, 성능에 영향을 미칩니다."
[SI_GRAPHICS_OPTIONS_VIDEO_VSYNC] = "수직 동기화"
[SI_GRAPHICS_OPTIONS_VIDEO_VSYNC_TOOLTIP] = "티어링이 발생하지 않도록 화면의 프레임 레이트를 모니터의 리프레시 레이트와 일치시킵니다."
[SI_GRAPHICS_OPTIONS_VIDEO_WINDOWS_AMBIENT_OCCLUSION_TYPE_TOOLTIP] = "빛을 막는 물체를 고려하여 그림자와 조명의 품질을 향상시킵니다. SSAO보다 HBAO가, HBAO보다 LSAO가 더 사실적이며 고성능을 요구합니다. 스크린 스페이스 GI는 LSAO에서 빛의 반사 효과를 추가로 향상시킵니다. 이 설정을 끄면 성능이 향상될 수 있습니다."
