[SI_STAT_TOOLTIP_ATTACK_POWER] = "당신이 물리 공격으로 입히는 피해량에 영향을 미칩니다."
[SI_STAT_TOOLTIP_CRITICAL_RESISTANCE] = "치명타 공격을 받을 시 받는 피해를 감소 시킵니다."
[SI_STAT_TOOLTIP_CRITICAL_STRIKE] = "주문 크리티컬보다 높을 경우, 데미지와 회복 능력에 보너스 효과를 부여합니다."
[SI_STAT_TOOLTIP_DIMINISHING_RETURNS] = "|t16:16:EsoUI/Art/Stats/diminishingReturns_icon.dds|t과도하게 추가된 스탯은 수치를 올리는 것이 점점 더 어려워집니다. 장비를 변경하고, 스킬이나 특성을 할당해서 스탯이 균등하게 오르도록하는 것이 좋습니다."
[SI_STAT_TOOLTIP_HEALTH_MAX] = "죽기 전 까지 견딜 수 있는 피해량에 영향을 주며, 피해, 회복, 보호 능력의 효율이 약간 증가합니다."
[SI_STAT_TOOLTIP_HEALTH_REGENERATION_COMBAT] = "전투시 2초마다 <<1>> 의 체력을 회복합니다."
[SI_STAT_TOOLTIP_HEALTH_REGENERATION_IDLE] = "비전투시 2초마다 <<1>> 의 체력을 회복합니다."
[SI_STAT_TOOLTIP_MAGICKA_MAX] = "매지카와 관련된 어빌리티를 얼마나 사용할 수 있을지에 영향을 미칩니다. 해당 자원이 최대 스태미나보다 높을 경우 피해, 치유, 보호 능력의 효율이 증가합니다."
[SI_STAT_TOOLTIP_MAGICKA_REGENERATION_COMBAT] = "전투시 2초마다 <<1>> 의 매지카를 회복합니다."
[SI_STAT_TOOLTIP_MAGICKA_REGENERATION_IDLE] = "비전투시 2초마다<<1>> 의 매지카를 회복합니다."
[SI_STAT_TOOLTIP_MITIGATION] = "내성"
[SI_STAT_TOOLTIP_PHYSICAL_PENETRATION] = "출혈, 질병, 물리 및 독 피해 공격이 대상의 물리 저항을 무시하도록 합니다."
[SI_STAT_TOOLTIP_PHYSICAL_RESIST] = "물리 공격으로부터 받는 데미지를 감소시킵니다. 출혈, 질병, 물리, 독 데미지에 영향을 미칩니다."
[SI_STAT_TOOLTIP_POWER] = "마법 피해 보다 높은 수치일 경우 전체 피해량 과 치유량에 영향을 줍니다."
[SI_STAT_TOOLTIP_SPELL_CRITICAL] = "무기 크리티컬보다 높을 경우, 데미지와 회복 능력의 효과에 보너스를 부여합니다."
[SI_STAT_TOOLTIP_SPELL_MITIGATION] = "받는 마법 피해를 감소시킵니다."
[SI_STAT_TOOLTIP_SPELL_PENETRATION] = "화염, 냉기, 마법, 전기 대미지가 대상의 마법 저항력을 무시하게 됩니다."
[SI_STAT_TOOLTIP_SPELL_POWER] = "무기 피해 보다 높은 수치일 경우 전체 피해량 과 치유량에 영향을 줍니다."
[SI_STAT_TOOLTIP_SPELL_RESIST] = "마법공격 피해량을 감소시킵니다. 화염, 냉기, 마법, 전격피해량이 해당됩니다."
[SI_STAT_TOOLTIP_STAMINA_MAX] = "스태미나와 관련된 어빌리티를 얼마나 사용할 수 있을지와 구르기, 막기 등과 같은 핵심 전투 메카닉에 영향을 미칩니다. 해당 자원이 최대 매지카보다 높을 경우 피해, 치유, 보호 능력의 효율이 증가합니다."
