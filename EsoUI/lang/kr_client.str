[SI_GRAPHICS_OPTIONS_VIDEO_DLSS_MODE] = "DLSS 모드"
[SI_GRAPHICS_OPTIONS_VIDEO_DLSS_MODE_TOOLTIP] = "NVIDIA DLSS가 켜지면 품질과 성능 개선 영역의 균형을 제어합니다."
[SI_GRAPHICS_OPTIONS_VIDEO_FSR_MODE] = "FSR 모드"
[SI_GRAPHICS_OPTIONS_VIDEO_FSR_MODE_TOOLTIP] = "FSR이 켜져 있는 경우, 품질과 성능 개선 영역의 균형을 조절합니다."
[SI_GRAPHICS_OPTIONS_VIDEO_GAMMA_ADJUSTMENT] = "감마 조절"
[SI_GRAPHICS_OPTIONS_VIDEO_GAMMA_ADJUSTMENT_TOOLTIP] = "게임의 전체적인 감마(밝기) 설정을 조절합니다. 성능에는 영향을 주지 않습니다. 게임 화면이 밝거나 어둡다고 할 때 변경합니다."
[SI_GRAPHICS_OPTIONS_VIDEO_GOD_RAYS] = "태양광 표현"
[SI_GRAPHICS_OPTIONS_VIDEO_GOD_RAYS_TOOLTIP] = "카메라의 위치에 따라 태양이 비추는 빛을 표현합니다. 이 옵션을 끄면 성능이 향상될 수 있습니다."
