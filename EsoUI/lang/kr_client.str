[SI_ZONECOMPLETIONTYPE10] = "눈에 띄는 장소"
[SI_ZONECOMPLETIONTYPE11] = "샬리도어의 도서관 장서"
[SI_ZONECOMPLETIONTYPE12] = "문두스 선돌"
[SI_ZONECOMPLETIONTYPE13] = "공개 던전"
[SI_ZONECOMPLETIONTYPE14] = "세트 제작대"
[SI_ZONECOMPLETIONTYPE2] = "관심장소(POI)"
[SI_ZONECOMPLETIONTYPE3] = "업적"
[SI_ZONECOMPLETIONTYPE4] = "성소"
[SI_ZONECOMPLETIONTYPE5] = "탐사지"
[SI_ZONECOMPLETIONTYPE6] = "그룹 탐사지"
[SI_ZONECOMPLETIONTYPE7] = "스카이샤드"
[SI_ZONECOMPLETIONTYPE8] = "월드 이벤트"
[SI_ZONECOMPLETIONTYPE9] = "월드 보스"
[SI_ZONECOMPLETIONTYPE_DESCRIPTION1] = "|cffffff지역 스토리 퀘스트|r는 지역 메인 스토리의 일부입니다. 이러한 퀘스트들을 완료하면 스킬 포인트, 경험치, 골드, 장비 등을 얻을 수 있습니다."
[SI_ZONECOMPLETIONTYPE_DESCRIPTION10] = "|cffffff눈에 띄는 장소|r는 세계에서 관심이 주목되는 곳입니다. 한 지역에서 모든 눈에 띄는 장소를 발견하면 그 지역의 길잡이 업적을 달성할 것입니다."
[SI_ZONECOMPLETIONTYPE_DESCRIPTION11] = "|cffffff샬리도어의 도서관 장서|r 세계 도처에 흩어져 있습니다. 이러한 책들은 독특한 보라색으로 빛나는 게 특징입니다. 이 책들을 발견해서 메이지 길드 랭크를 올리고 스킬라인을 향상시키세요."
[SI_ZONECOMPLETIONTYPE_DESCRIPTION12] = "|cffffff문두스 선돌|r은 일시적인 플레이어 버프의 형태로 은혜를 내려주는 장치입니다. 이 버프는 다른 문두스 선돌의 은혜를 받아 교체될 때까지 지속됩니다."
[SI_ZONECOMPLETIONTYPE_DESCRIPTION13] = "|cffffff공개 던전|r은 세계 각지에서 발견되는 오픈 월드 던전으로 4명으로 이루어진 그룹을 위해 설계된 던전입니다. 공개 던전을 완료하면 스킬 포인트, 경험치, 골드, 장비 등을 얻을 수 있습니다."
[SI_ZONECOMPLETIONTYPE_DESCRIPTION14] = "|cffffff세트 제작대|r는 특별한 세트 보너스가 있는 아이템을 제작할 수 있는 세계 각지의 위치입니다."
[SI_ZONECOMPLETIONTYPE_DESCRIPTION2] = "|cffffff흥미로운 장소|r는 한 지역 내의 전통, 인물, 그리고 위치를 탐구하는 독단적 이야기들입니다. 그곳은 당신에게 경험치, 골드, 그리고 장비를 보상으로 줄 수 있습니다."
[SI_ZONECOMPLETIONTYPE_DESCRIPTION4] = "|cffffff성소|r는 무료로 이용할 수 있으며, 발견되어 해제된 성소끼리 순식간에 이동할 수 있는 특별한 장소입니다. 소량의 골드를 지불하면, 어디서나 해제된 성소로 이동이 가능합니다."
[SI_ZONECOMPLETIONTYPE_DESCRIPTION5] = "|cffffff탐사지|r는 전역에 존재하며 혼자서도 가능한 던전입니다. 탐사지에는 항상 스카이샤드 1개와 세트 장비를 주는 보스가 있습니다."
[SI_ZONECOMPLETIONTYPE_DESCRIPTION6] = "|cffffff그룹 탐사지|r는 크래글론에서 발견되는 오픈 월드 던전으로, 4명으로 이루어진 그룹을 위해 설계된 던전입니다. 그룹 탐사지는 항상 스카이샤드 1개와 세트 아이템을 주는 보스가 있습니다."
[SI_ZONECOMPLETIONTYPE_DESCRIPTION7] = "|cffffff스카이샤드|r는 세계 곳곳에 흩어져 있으며 밝고 하얀 광선을 뿜어내는 것으로 확인할 수 있습니다. 세 개의 스카이샤드를 발견하면 스킬 포인트를 얻을 수 있는데, 이것으로 새로운 어빌리티를 해금하거나 변이할 수 있습니다."
[SI_ZONECOMPLETIONTYPE_DESCRIPTION8] = "어둠의 닻 등의 |cffffff월드 이벤트|r는 그룹을 이룬 모험가들이 도전하기에 최적화된 활동입니다. 월드 이벤트를 완료하면 경험치, 골드, 고품질의 장비가 주어집니다."
[SI_ZONECOMPLETIONTYPE_DESCRIPTION9] = "|cffffff월드 보스|r는그룹을 이룬 모험가들이 도전하도록 의도된 어려운 적입니다. 월드 보스를 쓰러뜨리면 고품질의 장비가 주어집니다."
[SI_ZONECOMPLETIONTYPE_PROGRESSDESCRIPTION10] = "<<2>>에서 <<1>> 눈에 띄는 장소 발견됨"
[SI_ZONECOMPLETIONTYPE_PROGRESSDESCRIPTION11] = "<<2>>에서 <<1>> 샬리도어의 도서관 장서 발견됨"
